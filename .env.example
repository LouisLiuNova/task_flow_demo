# Database Configuration
DATABASE_URL=sqlite:///./tasks.db

# Task Generation Configuration
# QPS for task generation
QPS=100
# Failure rate for tasks (0.0 to 1.0)
FAIL_RATE=0.2
# Maximum retry attempts for failed tasks
MAX_RETRY=3
# Timeout threshold in seconds
TIMEOUT_THRESHOLD=30
# Maximum execution time in seconds
MAX_TIME=40
# Minimum execution time in seconds
MIN_TIME=5

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TASK_TOPIC=task_input
KAFKA_RESULT_TOPIC=task_result
KAFKA_CONSUMER_GROUP=task_flow_demo

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=<green>{time:YYYY-MM-DD HH:mm:ss.SSS}</green> | <level>{level}</level> | <cyan>{name}</cyan>:<cyan>{function}</cyan>:<cyan>{line}</cyan> - <level>{message}</level>
LOG_FILE_PATH=
LOG_ROTATION=10 MB
LOG_RETENTION=7 days
