DATABASE_URL=sqlite:///./tasks.db
QPS=100
FAIL_RATE=0.2
MAX_RETRY=3
TIMEOUT_THRESHOLD=30
MAX_TIME=40
MIN_TIME=5
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TASK_TOPIC=task_input
KAFKA_RESULT_TOPIC=task_result
KAFKA_CONSUMER_GROUP=task_flow_demo
REDIS_URL=redis://redis:6379/0
REDIS_RESULT_CHANNEL=task_result_channel
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_BACKEND_URL=redis://redis:6379/0
CELERY_QUEUE=
CELERY_DEFAULT_QUEUE=query_queue
CELERY_WORKER_TASK_TYPE=query
LOG_LEVEL=INFO
LOG_FORMAT=<green>{time:YYYY-MM-DD HH:mm:ss.SSS}</green> | <level>{level}</level> | <cyan>{name}</cyan>:<cyan>{function}</cyan>:<cyan>{line}</cyan> - <level>{message}</level>
LOG_FILE_PATH=
LOG_ROTATION=10 MB
LOG_RETENTION=7 days
